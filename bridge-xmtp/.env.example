# XMTP Bridge Configuration
# Copy this file to .env and fill in your values

# Agent's Ethereum wallet private key (0x-prefixed hex format)
# This is like a bot token - it identifies your agent on the XMTP network
# Generate one at: https://docs.xmtp.org/agents/get-started/build-an-agent
XMTP_WALLET_KEY=0x...

# Database encryption key (exactly 64 hex characters)
# This encrypts the local SQLite database that stores XMTP state
# Generate one using: openssl rand -hex 32
XMTP_DB_ENCRYPTION_KEY=

# XMTP network environment
# - dev: Development network (recommended for testing)
# - production: Production network
XMTP_ENV=dev

# HTTP server port for bridge API
XMTP_BRIDGE_PORT=18792

# Python channel callback URL for inbound messages
PYTHON_CALLBACK_URL=http://localhost:18791/xmtp/inbound
